{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Doqo Docs",
  "description": "Everything you need to set up your AI chatbot — knowledge base, embed widget, WhatsApp, and API.",
  "colors": {
    "primary": "#E05C3A",
    "light": "#F28C6E",
    "dark": "#C94E2E"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "https://doqo.in"
        },
        {
          "anchor": "Dashboard",
          "icon": "layout-dashboard",
          "href": "https://doqo.in/dashboard"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "mailto:support@doqo.in"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Getting Started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "getting-started/introduction",
          "getting-started/quickstart"
        ]
      },
      {
        "group": "Knowledge Base",
        "icon": "book-open",
        "expanded": true,
        "pages": [
          "knowledge-base/overview",
          "knowledge-base/supported-files",
          "knowledge-base/best-practices"
        ]
      },
      {
        "group": "Embed Widget",
        "icon": "code",
        "expanded": true,
        "pages": [
          "embed/overview",
          "embed/html",
          "embed/shopify",
          "embed/wordpress",
          "embed/wix",
          "embed/webflow",
          "embed/react",
          "embed/nextjs"
        ]
      },
      {
        "group": "Shareable Chat Link",
        "icon": "link",
        "expanded": false,
        "pages": [
          "shareable-link"
        ]
      },
      {
        "group": "API Reference",
        "icon": "terminal",
        "expanded": false,
        "pages": [
          "api-reference/public-chat"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Go to Dashboard",
      "href": "https://doqo.in/dashboard"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/doqo_in",
      "linkedin": "https://linkedin.com/company/doqo"
    }
  }
}
